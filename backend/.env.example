# API ключ для LeakCheck.io
# Получить ключ: https://leakcheck.io/
LEAKCHECK_API_KEY=your_api_key_here

# PostgreSQL Database URL (Neon, Supabase, etc.)
# Формат: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Разрешённые Origins для CORS (через запятую, или * для всех)
# Для продакшна укажите домен вашего фронтенда
ALLOWED_ORIGINS=*
