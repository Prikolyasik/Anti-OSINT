# ==========================================
# Корневой .gitignore для Anti-OSINT
# ==========================================

# Файлы окружения (содержат секретные ключи)
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt
.tox
.coverage
.coverage.*
.cache
nosetests.xml
.coverage.xml
*.cover
*.log
.gitattributes

# Виртуальное окружение
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Reports (генерируемые PDF)
backend/reports/
*.pdf

# Очищенные изображения (генерируемые)
backend/cleaned_images/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build
frontend/build/
frontend/dist/

# Vercel
.vercel/

# Qwen Code (AI assistant)
.qwen/
QWEN.md

# Тесты и покрытие (если появятся)
htmlcov/
.junit.xml

# Misc
*.tmp
*.bak
